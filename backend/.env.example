# Backend Environment Variables

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/thietbidientu

# JWT Secret
JWT_SECRET=your_very_secret_jwt_key_here_change_this_in_production

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Google Gemini AI
# Lấy API key tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Groq API (Primary LLM)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama3-8b-8192
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_CB_FAILURE_THRESHOLD=4
GROQ_CB_OPEN_TIMEOUT_MS=45000

# Local embeddings + Atlas vector search
TRANSFORMERS_CACHE=.cache/transformers
EMBEDDING_DIMENSION=384
MONGODB_KNOWLEDGE_VECTOR_INDEX=knowledge_embedding_index
MONGODB_PRODUCT_VECTOR_INDEX=product_embedding_index
MONGODB_KNOWLEDGE_COLLECTION=knowledgedocuments
MONGODB_PRODUCT_EMBEDDING_COLLECTION=productembeddings
# ZaloPay Sandbox Configuration
# Đăng ký tại: https://sandbox.zalopay.vn/
ZALO_APP_ID=your-zalo-app-id
ZALO_KEY1=your-zalo-key1
ZALO_KEY2=your-zalo-key2
ZALO_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
ZALO_CALLBACK_URL=http://localhost:5000/api/zalopay/callback

# Server Port
PORT=5000
