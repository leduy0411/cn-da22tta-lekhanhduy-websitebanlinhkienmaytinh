# ============================================
# Docker Compose Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# MongoDB (for local Docker MongoDB)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=admin123

# MongoDB URI (for cloud MongoDB Atlas - overrides local)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/thietbidientu

# Backend
JWT_SECRET=your_jwt_secret_key_here
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GEMINI_API_KEY=your_gemini_api_key
FRONTEND_URL=http://localhost:3000

# AI Service is automatically configured via docker-compose
# AI_SERVICE_URL=http://ai-service:8000
